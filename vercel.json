{
  "version": 2,
  "builds": [
    {
      "src": "api/[...route].js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/\\.well-known/credora-agent\\.json",
      "dest": "/api/[...route].js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...route].js"
    }
  ]
}
