{
  "version": 2,
  "builds": [
    {
      "src": "api/[...route].js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/[...route].js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/health" },
    { "source": "/.well-known/credora-agent.json", "destination": "/api/discovery" },
    { "source": "/(.*)", "destination": "/api/$1" }
  ]
}
